# Uninstall script for game-of-life.
# Run via the `uninstall` target (e.g. `make uninstall`).
# @VAR@ tokens are substituted at configure time; ${...} / $ENV{...} are left
# literal and evaluated when this script runs.

include("@CMAKE_CURRENT_SOURCE_DIR@/cmake/RealUserHome.cmake")

# --- Executable -------------------------------------------------------------
set(exe "@CMAKE_INSTALL_FULL_BINDIR@/game-of-life")
if(EXISTS "${exe}")
    message(STATUS "Removing ${exe}")
    file(REMOVE "${exe}")
else()
    message(STATUS "Not found (skipped): ${exe}")
endif()

# --- Config directory (respects HOME / XDG_CONFIG_HOME at run time) ----------
# See RealUserHome.cmake: under `sudo make uninstall`, $ENV{HOME} is root's, so
# the fallback below resolves the real invoking user's home instead (matching
# where the fixed install script actually placed things).
set(cfg_home "$ENV{XDG_CONFIG_HOME}")
if(cfg_home STREQUAL "")
    gol_real_home(real_home)
    set(cfg_home "${real_home}/.config")
endif()
set(cfg_dir "${cfg_home}/game-of-life")

# Remove the runtime settings file and any legacy default.cells (older versions
# kept the default pattern here before it moved to the saves directory).
foreach(name "default.cells" "settings.json")
    set(cfg "${cfg_dir}/${name}")
    if(EXISTS "${cfg}")
        message(STATUS "Removing ${cfg}")
        file(REMOVE "${cfg}")
    else()
        message(STATUS "Not found (skipped): ${cfg}")
    endif()
endforeach()

if(EXISTS "${cfg_dir}")
    file(GLOB remaining "${cfg_dir}/*")
    if(remaining STREQUAL "")
        message(STATUS "Removing empty directory ${cfg_dir}")
        file(REMOVE_RECURSE "${cfg_dir}")
    endif()
endif()

# --- Data directory: the bundled patterns we shipped ------------------------
# Remove exactly the patterns install put there, but NEVER the user's own saved
# patterns; the saves and data directories are removed only if they end up empty.
set(data_home "$ENV{XDG_DATA_HOME}")
if(data_home STREQUAL "")
    gol_real_home(real_home)
    set(data_home "${real_home}/.local/share")
endif()
set(data_dir "${data_home}/game-of-life")
set(saves_dir "${data_dir}/saves")

set(bundled "@GOL_BUNDLED_PATTERNS_STR@")
separate_arguments(bundled)
foreach(pat ${bundled})
    set(f "${saves_dir}/${pat}")
    if(EXISTS "${f}")
        message(STATUS "Removing ${f}")
        file(REMOVE "${f}")
    else()
        message(STATUS "Not found (skipped): ${f}")
    endif()
endforeach()

foreach(dir "${saves_dir}" "${data_dir}")
    if(EXISTS "${dir}")
        file(GLOB remaining "${dir}/*")
        if(remaining STREQUAL "")
            message(STATUS "Removing empty directory ${dir}")
            file(REMOVE_RECURSE "${dir}")
        else()
            message(STATUS "Keeping non-empty directory ${dir} (your saved patterns)")
        endif()
    endif()
endforeach()
